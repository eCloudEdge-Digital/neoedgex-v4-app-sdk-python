{
  "nodes": [
    {
      "id": "custom-httpclient-env-node",
      "type": "app",
      "data": {
        "name": "custom-httpclient-env-node",
        "inputs": {
          "input1": [
            { "key": "temperature", "type": "int64", "format": "int64" }
          ],
          "input2": [
            { "key": "running", "type": "bool", "format": "bool" }
          ],
          "input3": [
            { "key": "message", "type": "string", "format": "string" }
          ]
        },
        "outputs": {
          "output1": [
            { "key": "api_path", "type": "string", "format": "string" },
            { "key": "response_status", "type": "int64", "format": "int64" }
          ]
        },
        "application": {
          "key": "example-app",
          "version": "1.0.0"
        },
        "settings": {}
      }
    }
  ],
  "mock": {
    "messageInterval": "1s",
    "messages": [
      {
        "nodeID": "custom-httpclient-env-node",
        "handle": "input1",
        "data": {
          "temperature": { "type": "int64", "format": "int64", "value": "25" }
        }
      },
      {
        "nodeID": "custom-httpclient-env-node",
        "handle": "input2",
        "data": {
          "running": { "type": "bool", "format": "bool", "value": "true" }
        }
      },
      {
        "nodeID": "custom-httpclient-env-node",
        "handle": "input3",
        "data": {
          "message": { "type": "string", "format": "string", "value": "hello" }
        }
      }
    ]
  }
}
